{# ============================================================
   partials/macros.njk — Reusable components (seperti macro di Twig)
   Cara pakai: {% from "partials/macros.njk" import card, badge, alert %}
   ============================================================ #}

{# ── Card Component ──────────────────────────────────────────
   Contoh: {{ card(title="Judul", desc="Deskripsi", href="/link.html") }}
#}
{% macro card(title, desc, href="#", icon="📄", tag="") %}
<a href="{{ href }}" class="group block p-6 rounded-2xl border border-gray-200 hover:border-blue-300 hover:shadow-lg transition-all duration-300 bg-white">
  <div class="flex items-start gap-4">
    <span class="text-3xl">{{ icon }}</span>
    <div class="flex-1 min-w-0">
      {% if tag %}
        <span class="inline-block px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-700 rounded-full mb-2">{{ tag }}</span>
      {% endif %}
      <h3 class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors truncate">{{ title }}</h3>
      <p class="text-sm text-gray-500 mt-1 line-clamp-2">{{ desc }}</p>
    </div>
  </div>
</a>
{% endmacro %}


{# ── Badge Component ──────────────────────────────────────────
   Contoh: {{ badge("Baru", "blue") }}
   Warna: blue | green | red | yellow | gray
#}
{% macro badge(text, color="blue") %}
{% set colors = {
  "blue":   "bg-blue-100 text-blue-700",
  "green":  "bg-green-100 text-green-700",
  "red":    "bg-red-100 text-red-700",
  "yellow": "bg-yellow-100 text-yellow-700",
  "gray":   "bg-gray-100 text-gray-700"
} %}
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ colors[color] }}">
  {{ text }}
</span>
{% endmacro %}


{# ── Alert Component ──────────────────────────────────────────
   Contoh: {{ alert("Berhasil disimpan!", "success") }}
   Tipe: success | error | warning | info
#}
{% macro alert(message, type="info") %}
{% set styles = {
  "success": { "bg": "bg-green-50 border-green-200 text-green-800", "icon": "✅" },
  "error":   { "bg": "bg-red-50 border-red-200 text-red-800",       "icon": "❌" },
  "warning": { "bg": "bg-yellow-50 border-yellow-200 text-yellow-800", "icon": "⚠️" },
  "info":    { "bg": "bg-blue-50 border-blue-200 text-blue-800",    "icon": "ℹ️" }
} %}
<div class="flex items-start gap-3 px-4 py-3 rounded-xl border {{ styles[type].bg }}">
  <span>{{ styles[type].icon }}</span>
  <p class="text-sm font-medium">{{ message }}</p>
</div>
{% endmacro %}


{# ── Button Component ──────────────────────────────────────────
   Contoh: {{ btn("Klik Saya", "/halaman.html", "primary") }}
   Variant: primary | secondary | outline | ghost
#}
{% macro btn(label, href="#", variant="primary") %}
{% set variants = {
  "primary":   "bg-blue-600 hover:bg-blue-700 text-white shadow-sm",
  "secondary": "bg-gray-900 hover:bg-gray-800 text-white shadow-sm",
  "outline":   "border border-gray-300 hover:border-gray-400 text-gray-700 hover:bg-gray-50",
  "ghost":     "text-gray-600 hover:text-gray-900 hover:bg-gray-100"
} %}
<a href="{{ href }}" class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 {{ variants[variant] }}">
  {{ label }}
</a>
{% endmacro %}
