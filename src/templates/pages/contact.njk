{# ============================================================
   pages/contact.njk — Halaman Kontak
   ============================================================ #}
{% extends "layouts/base.njk" %}
{% from "partials/macros.njk" import badge, btn, alert %}

{% block title %}Kontak — {{ siteName }}{% endblock %}

{% block content %}

  <section class="bg-gray-50 border-b border-gray-200 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {{ badge("Kontak", "gray") }}
      <h1 class="mt-4 text-3xl sm:text-4xl font-bold text-gray-900">Hubungi Kami</h1>
      <p class="mt-3 text-gray-500">Kami siap membantu. Kirimkan pesan dan kami akan membalas segera.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-lg space-y-5">
      {{ alert("Ini contoh form statis. Di project nyata, hubungkan ke Formspree, Netlify Forms, atau backend.", "info") }}

      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Nama</label>
          <input type="text" placeholder="Nama lengkap kamu"
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
          <input type="email" placeholder="email@contoh.com"
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Pesan</label>
          <textarea rows="5" placeholder="Tulis pesanmu di sini..."
            class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm resize-none"></textarea>
        </div>
      </div>

      <div class="flex gap-3 pt-2">
        {{ btn("Kirim Pesan", "#", "primary") }}
        {{ btn("← Kembali", "/index.html", "ghost") }}
      </div>
    </div>
  </section>

{% endblock %}
